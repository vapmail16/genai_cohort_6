# LangSmith and OpenAI API Configuration
# Copy this file to .env and add your actual API keys

# OpenAI API Key (required)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LangSmith API Key (required)
# Get from: https://smith.langchain.com/settings
LANGSMITH_API_KEY=ls-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Override default project name
# LANGCHAIN_PROJECT=my-custom-project-name

# Optional: Custom LangSmith endpoint (usually not needed)
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com