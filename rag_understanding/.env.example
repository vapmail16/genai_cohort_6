# rag_understanding/.env.example
# Copy this file to .env and fill in your values
# This file is safe to commit — .env is gitignored

# ── Qdrant Cloud (same collection used in the vector_db_understanding lab) ──
QDRANT_URL=https://your-cluster-id.us-east-1-1.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=cohort_pdf_demo

# ── OpenAI (used for the generation step in the RAG pipeline) ──
OPENAI_API_KEY=sk-your_openai_key_here
