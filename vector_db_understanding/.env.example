# Qdrant — REST API (Qdrant Cloud or self-hosted with TLS)
# Copy to `.env` in this folder and fill in values. Never commit `.env`.

# Cluster URL from Qdrant Cloud (include port, usually :6333)
# Example: https://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.us-east.aws.cloud.qdrant.io:6333
QDRANT_URL=

# API key from Qdrant Cloud (Cluster → API Keys) or your server’s key
QDRANT_API_KEY=

# Default collection name for the PDF lab (created if missing)
QDRANT_COLLECTION=cohort_pdf_demo
